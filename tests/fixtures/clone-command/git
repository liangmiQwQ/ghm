#!/bin/sh
# Mock git for testing - simulates git clone

if [ "$1" = "clone" ]; then
  # Handle both: git clone <url> <target> and git clone --progress <url> <target>
  if [ "$2" = "--progress" ]; then
    target="$4"
  else
    target="$3"
  fi
  mkdir -p "$target"
  echo "Cloning into '$target'..."
  exit 0
fi

# For any other git command, just succeed
echo "mock-git: $*"
exit 0
