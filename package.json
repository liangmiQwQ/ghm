{
  "name": "@liangmi/mo",
  "version": "1.2.0",
  "description": "Manage your open source projects",
  "homepage": "https://github.com/liangmiQwQ/mo#readme",
  "bugs": {
    "url": "https://github.com/liangmiQwQ/mo/issues"
  },
  "license": "MIT",
  "author": "Liang Mi <hi@liangmi.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangmiQwQ/mo.git"
  },
  "bin": {
    "mo": "./bin/mo.mjs",
    "mo-inner": "./bin/mo-inner.mjs"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "config_schema.json"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev:i": "tsx scripts/install.ts",
    "dev:uni": "tsx scripts/uninstall.ts",
    "preview": "node bin/cli.mjs",
    "test": "vp test run",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "release": "bumpp"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "@types/which": "^3.0.4",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.1.0",
    "cac": "^7.0.0",
    "ink": "^7.0.3",
    "picocolors": "^1.1.1",
    "react": "^19.2.6",
    "tinyexec": "^1.1.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "untildify": "^6.0.0",
    "vite-plus": "^0.1.21",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.21",
    "which": "^7.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "inlinedDependencies": {
    "cac": "7.0.0",
    "picocolors": "1.1.1",
    "untildify": "6.0.0"
  }
}
